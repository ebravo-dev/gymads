// Configurar rutas del servidor HTTP      // Apagar todos los LEDs de estado mientras se procesa

void setupServerRoutes() {      turnOffAllStatusLeds();

  // Rutas para comunicación con la aplicación Flutter      

  server.on("/api/uid", HTTP_GET, handleGetUid);      // Detener la tarjeta actual

  server.on("/api/status", HTTP_GET, handleStatus);      rfidReader.PICC_HaltA();

  server.on("/api/membership", HTTP_POST, handleMembershipStatus);      rfidReader.PCD_StopCrypto1();

  server.on("/api/discover", HTTP_GET, handleDiscover);    }

    }

  // Habilitar CORS para permitir solicitudes desde la aplicación  

  server.enableCORS(true);  // Verificar estado de conexión WiFi periódicamente

    static unsigned long lastWiFiCheck = 0;

  Serial.println("Rutas del servidor HTTP configuradas");  if (millis() - lastWiFiCheck > 10000) { // Cada 10 segundos

}    checkWiFiConnection();

    lastWiFiCheck = millis();

// Manejador para la ruta /api/uid  }

void handleGetUid() {}

  server.send(200, "text/plain", lastUid);

  // =================== FUNCIONES BLUETOOTH LE ===================

  // Después de enviar el UID, lo reseteamos

  if (lastUid != "NO_CARD") {// Inicializar Bluetooth LE

    lastUid = "NO_CARD";void initializeBluetooth() {

  }  Serial.println("Inicializando Bluetooth LE...");

}  

  // Inicializar BLE

// Manejador para la ruta /api/status  BLEDevice::init(BT_DEVICE_NAME.c_str());

void handleStatus() {  

  DynamicJsonDocument doc(256);  // Crear servidor BLE

  doc["status"] = "OK";  pServer = BLEDevice::createServer();

  doc["wifi_connected"] = wifiConnected;  pServer->setCallbacks(new MyServerCallbacks());

  doc["last_uid"] = lastUid;

  doc["ip_address"] = WiFi.localIP().toString();  // Crear servicio BLE (Nordic UART Service)

    BLEService *pService = pServer->createService(SERVICE_UUID);

  String response;

  serializeJson(doc, response);  // Crear característica TX (para enviar datos al cliente)

  server.send(200, "application/json", response);  pTxCharacteristic = pService->createCharacteristic(

}                      CHARACTERISTIC_UUID_TX,

                      BLECharacteristic::PROPERTY_NOTIFY

// Manejador para la ruta /api/discover - Identificación del dispositivo                    );

void handleDiscover() {  pTxCharacteristic->addDescriptor(new BLE2902());

  DynamicJsonDocument doc(512);

  doc["device_id"] = "ESP32_RFID_GYMADS";  // Crear característica RX (para recibir datos del cliente)

  doc["device_type"] = "RFID_READER";  pRxCharacteristic = pService->createCharacteristic(

  doc["version"] = "4.0.0";                      CHARACTERISTIC_UUID_RX,

  doc["manufacturer"] = "GYMADS";                      BLECharacteristic::PROPERTY_WRITE

  doc["wifi_connected"] = wifiConnected;                    );

  doc["status"] = "ONLINE";  pRxCharacteristic->setCallbacks(new MyCallbacks());

  doc["uptime"] = millis();

    // Iniciar el servicio

  if (wifiConnected) {  pService->start();

    doc["ip_address"] = WiFi.localIP().toString();

    doc["gateway"] = WiFi.gatewayIP().toString();  // Configurar advertising

    doc["subnet"] = WiFi.subnetMask().toString();  BLEAdvertising *pAdvertising = BLEDevice::getAdvertising();

    doc["dns"] = WiFi.dnsIP().toString();  pAdvertising->addServiceUUID(SERVICE_UUID);

    doc["mac_address"] = WiFi.macAddress();  pAdvertising->setScanResponse(false);

    doc["signal_strength"] = WiFi.RSSI();  pAdvertising->setMinPreferred(0x0);

    doc["ssid"] = WiFi.SSID();  

  }  // Iniciar advertising

    BLEDevice::startAdvertising();

  String response;  

  serializeJson(doc, response);  bluetoothEnabled = true;

  server.send(200, "application/json", response);  Serial.println("Bluetooth LE iniciado como: " + BT_DEVICE_NAME);

}  Serial.println("Esperando conexiones BLE...");

  

// Manejador para recibir el estado de membresía y controlar LEDs  // LED parpadeando para indicar que está esperando conexión

void handleMembershipStatus() {  digitalWrite(LED_BLUETOOTH, LOW);

  if (server.hasArg("plain")) {}

    String body = server.arg("plain");

    DynamicJsonDocument doc(256);// Manejar conexiones BLE

    void handleBluetoothConnections() {

    DeserializationError error = deserializeJson(doc, body);  // Manejar reconexiones

    if (error) {  if (!deviceConnected && oldDeviceConnected) {

      server.send(400, "application/json", "{\"error\":\"Invalid JSON\"}");    delay(500); // Dar tiempo al cliente para procesar la desconexión

      return;    pServer->startAdvertising();

    }    Serial.println("Reiniciando advertising...");

        oldDeviceConnected = deviceConnected;

    String status = doc["status"];  }

    controlStatusLeds(status);  

      // Nueva conexión

    server.send(200, "application/json", "{\"success\":true}");  if (deviceConnected && !oldDeviceConnected) {

  } else {    oldDeviceConnected = deviceConnected;

    server.send(400, "application/json", "{\"error\":\"No data received\"}");    Serial.println("Nueva conexión BLE establecida");

  }  }

}  

  bluetoothClientConnected = deviceConnected;

